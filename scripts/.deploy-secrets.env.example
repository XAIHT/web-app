# Local-only secrets used by the vm-*.sh deploy scripts.
# Copy this file to scripts/.deploy-secrets.env and fill in real values.
# scripts/.deploy-secrets.env is gitignored — never commit it.

# MySQL password for the xaiht-app user in Cloud SQL
DB_PASSWORD=

# Google OAuth client secret from GCP Console > APIs & Services > Credentials
GOOGLE_CLIENT_SECRET=

# Google OAuth client ID — public information, kept here for convenience
GOOGLE_CLIENT_ID=

# Google "sub" of the account to auto-promote to admin on sign-in (optional)
OWNER_GOOGLE_SUB=
