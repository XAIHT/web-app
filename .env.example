# Local development environment.
# Copy this to .env and fill in values. .env is gitignored — never commit it.
# Production values live in /etc/xaiht/app.env on the GCP VM.

# Node ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Session JWT signing secret (HS256). 64-char hex recommended.
# Rotating this invalidates every existing session.
APP_SECRET=

# Database ─────────────────────────────────────────────────────
# Local:        mysql://root:pass@127.0.0.1:3306/xaiht
# Prod (on VM): mysql://xaiht-app:<password>@127.0.0.1:3306/xaiht (via cloud-sql-proxy)
DATABASE_URL=

# Google OAuth ─────────────────────────────────────────────────
# Create a Web application OAuth client at:
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${PUBLIC_BASE_URL}/api/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public origin used to build the OAuth redirect_uri. Must EXACTLY match what's
# registered in the GCP OAuth client. Examples:
#   http://localhost:3000  (dev)
#   https://xaiht.org      (prod)
PUBLIC_BASE_URL=http://localhost:3000

# Google "sub" claim of the account that should auto-promote to role=admin
# on first sign-in. Find it after your first login by querying the users table
# (column is named `unionId` for legacy schema reasons).
OWNER_GOOGLE_SUB=
